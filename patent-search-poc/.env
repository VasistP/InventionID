# ============================================================================
# API Keys Configuration
# ============================================================================

# RECOMMENDED: Use Claude for best results with --llm-web-search
# Claude supports actual web search to find current, real patents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL: Use OpenAI (no real web search, uses LLM knowledge only)
# OPENAI_API_KEY=sk-proj-your-key-here

# ============================================================================
# Default Model Selection
# ============================================================================

# RECOMMENDED: Claude Sonnet 4 (supports web search)
DEFAULT_MODEL=claude-sonnet-4

# Alternative options:
# DEFAULT_MODEL=claude-opus-4        # More capable, more expensive, supports web search
# DEFAULT_MODEL=gpt-4o               # Good for analysis, no web search support
# DEFAULT_MODEL=gpt-4o-mini          # Fast and cheap, no web search support

# ============================================================================
# Notes:
# ============================================================================
# - Get Anthropic API key: https://console.anthropic.com/settings/keys
# - Get OpenAI API key: https://platform.openai.com/api-keys
#
# - For --llm-web-search to work with real web searches, use Claude models
# - OpenAI models will fall back to using their training data knowledge
# ============================================================================